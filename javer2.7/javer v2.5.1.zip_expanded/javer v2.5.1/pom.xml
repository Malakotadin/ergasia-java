<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>javer_v2.5.1.zip_expanded</groupId>
  <artifactId>javer_v2.5.1.zip_expanded</artifactId>
  <version>0.0.1-SNAPSHOT</version>
  <name>Javeraki_maven_project</name>
  <build>
    <sourceDirectory>javer v2.5.1/src</sourceDirectory>
    <resources>
      <resource>
        <directory>javer v2.5.1/src</directory>
        <excludes>
          <exclude>**/*.java</exclude>
        </excludes>
      </resource>
    </resources>
    <plugins>
      <plugin>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <release>25</release>
        </configuration>
      </plugin>
    </plugins>
  </build>
  <dependencies>
  <dependency>
    <groupId>org.postgresql</groupId>
    <artifactId>postgresql</artifactId>
    <version>42.7.10</version> <!-- αν και δεν ειναι αυτη η  εκδοση μου , δεν ξερω τι σκατα -->
</dependency>
  </dependencies>
  
</project>